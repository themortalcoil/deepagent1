# Ollama configuration
OLLAMA_BASE_URL=http://localhost:11434

# Model selection (Ollama Cloud models)
# Available cloud models:
#   deepseek-v4-flash:cloud  — 284B MoE, fast, top coding benchmarks (recommended)
#   deepseek-v4-pro:cloud   — 158B, frontier reasoning (highest quality, most quota)
#   kimi-k2.6:cloud          — 1T MoE, agentic/swarm, vision, long-horizon coding
#   glm-5:cloud               — 756B, agentic engineering (original orchestrator)
#   glm-5.1:cloud             — 756B, agentic engineering (original react-dev)
#   qwen3.5:cloud             — 397B, multimodal, BF16 (good general-purpose)
#   qwen3-coder-next:cloud    — 80B, coding-focused, agentic workflows
#   nemotron-3-super:cloud    — 120B MoE (12B active), efficient multi-agent
#   gemma4:31b-cloud          — 33B, lightweight reasoning, vision
ORCHESTRATOR_MODEL=deepseek-v4-flash:cloud
REACT_DEV_MODEL=deepseek-v4-flash:cloud

# Output directory for generated projects (outside project tree to avoid
# triggering LangGraph Server's file watcher on every write)
# Defaults to ~/.deepagent/output if not set
# OUTPUT_DIR=~/.deepagent/output